@model NickysManicurePedicure.ViewModels.HomePageViewModel

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="eyebrow">Cape Town luxury nail care</span>
                <h1 class="hero-title">Luxury manicure and pedicure care for women who love elegance done well.</h1>
                <p class="hero-copy">A polished, high-touch salon experience in Mowbray, Cape Town. Nicky brings over 8 years of trusted expertise to beautifully finished nails, calm appointments, and service that feels intentionally premium.</p>
                <div class="hero-actions">
                    <a class="btn btn-brand btn-lg" asp-controller="Booking" asp-action="Index">Book Your Appointment</a>
                    <a class="btn btn-outline-brand btn-lg" asp-controller="Services" asp-action="Index">View Services</a>
                </div>
                <div class="hero-metrics">
                    <div class="metric-chip">
                        <strong>8+</strong>
                        <span>Years of experience</span>
                    </div>
                    <div class="metric-chip">
                        <strong>Cape Town</strong>
                        <span>Mowbray location</span>
                    </div>
                    <div class="metric-chip">
                        <strong>Luxury Care</strong>
                        <span>Refined one-to-one service</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-showcase">
                    <div class="hero-visual">
                        <img
                            class="hero-visual-media"
                            src="@Model.HeroImage.ImageUrl"
                            alt="@Model.HeroImage.AltText"
                            loading="eager"
                            fetchpriority="high"
                            decoding="async" />
                        <div class="hero-badge">
                            <i class="bi bi-stars"></i>
                            <span>Premium Beauty Appointments</span>
                        </div>
                    </div>
                    <div class="hero-card hero-overlay-card">
                        <div class="hero-stat">
                            <strong>Soft luxury finishes</strong>
                            <span>Nudes, blush tones, modern classics, and event-ready polish.</span>
                        </div>
                        <div class="hero-stat">
                            <strong>Trust-worthy care</strong>
                            <span>Consistent quality, attentive detail, and a graceful appointment flow.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="trust-ribbon">
    <div class="container">
        <div class="trust-ribbon-grid">
            <div class="trust-ribbon-item">
                <i class="bi bi-award"></i>
                <span>Experienced luxury nail technician</span>
            </div>
            <div class="trust-ribbon-item">
                <i class="bi bi-heart"></i>
                <span>Client-first, detail-led appointments</span>
            </div>
            <div class="trust-ribbon-item">
                <i class="bi bi-gem"></i>
                <span>Elegant finishes with a premium aesthetic</span>
            </div>
        </div>
    </div>
</section>

<section class="section-space">
    <div class="container">
        @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
        {
            Eyebrow = "Signature services",
            Title = "A signature service menu created for polished everyday luxury",
            Description = "From impeccable maintenance appointments to occasion-ready finishes, each treatment is designed to feel elevated and beautifully considered."
        })

        <div class="row g-4">
            @foreach (var service in Model.FeaturedServices)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="service-card h-100">
                        <div class="service-icon"><i class="bi bi-flower1"></i></div>
                        <div class="service-meta">
                            <span>@service.DurationLabel</span>
                            <span>@service.PriceFromLabel</span>
                        </div>
                        <h3>@service.Name</h3>
                        <p>@service.Description</p>
                        <a class="service-link" asp-controller="Booking" asp-action="Index">Book this service <i class="bi bi-arrow-right"></i></a>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section-space pt-0">
    <div class="container">
        <div class="cta-panel booking-cta-panel">
            <div>
                <span class="eyebrow">Ready to book?</span>
                <h2>Claim a polished appointment slot before your ideal time gets taken.</h2>
                <p>Use the booking form below or jump to the dedicated booking page for a focused appointment request experience.</p>
            </div>
            <div class="cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="Booking" asp-action="Index">Book Now</a>
                <a class="btn btn-outline-brand btn-lg" href="#home-booking-form">Book on This Page</a>
            </div>
        </div>
    </div>
</section>

<section class="section-space bg-blush">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Why women choose Nicky",
                    Title = "Luxury is as much about how you feel as how your nails look",
                    Description = "From your first message to your final finish, the experience is shaped around warmth, professionalism, and thoughtful care.",
                    AlignmentClass = "text-start"
                })
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-md-4"><div class="trust-card"><i class="bi bi-stars trust-icon"></i><strong>High-end feel</strong><p>Refined styling, premium care, and a calm appointment flow.</p></div></div>
                    <div class="col-md-4"><div class="trust-card"><i class="bi bi-person-heart trust-icon"></i><strong>Client first</strong><p>Every service is shaped around your lifestyle, goals, and comfort.</p></div></div>
                    <div class="col-md-4"><div class="trust-card"><i class="bi bi-patch-check trust-icon"></i><strong>Consistent quality</strong><p>Professional standards that help you book with confidence.</p></div></div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_TestimonialsSection", Model.Testimonials)

<section class="section-space gallery-teaser-section">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Gallery teaser",
                    Title = "A visual style rooted in femininity, softness, and polished detail",
                    Description = "The gallery is designed to showcase future client work with the same premium feel as the salon experience.",
                    AlignmentClass = "text-start"
                })
                <a class="btn btn-outline-brand" asp-controller="Gallery" asp-action="Index">Explore Gallery</a>
            </div>
            <div class="col-lg-7">
                <div class="gallery-teaser-grid">
                    <article class="gallery-teaser-card tall">
                        <img
                            src="@Model.PreviewImages[0].ImageUrl"
                            alt="@Model.PreviewImages[0].AltText"
                            loading="lazy"
                            decoding="async" />
                        <span>@Model.PreviewImages[0].Caption</span>
                    </article>
                    <article class="gallery-teaser-card">
                        <img
                            src="@Model.PreviewImages[1].ImageUrl"
                            alt="@Model.PreviewImages[1].AltText"
                            loading="lazy"
                            decoding="async" />
                        <span>@Model.PreviewImages[1].Caption</span>
                    </article>
                    <article class="gallery-teaser-card accent">
                        <img
                            src="@Model.PreviewImages[2].ImageUrl"
                            alt="@Model.PreviewImages[2].AltText"
                            loading="lazy"
                            decoding="async" />
                        <span>@Model.PreviewImages[2].Caption</span>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-space" id="home-booking-form">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Appointment request",
                    Title = "Reserve your next premium manicure or pedicure appointment",
                    Description = "Share your preferred service and timing. We will confirm availability and make the booking process feel easy, personal, and polished.",
                    AlignmentClass = "text-start"
                })
                <div class="booking-note">
                    <i class="bi bi-telephone-fill"></i>
                    <span>Prefer a faster response? Call or WhatsApp for direct assistance.</span>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="form-panel">
                    @await Html.PartialAsync("_BookingRequestForm", Model.BookingForm)
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_FaqSection", Model.FaqItems)
@await Html.PartialAsync("_ContactCallout")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
