@model NickysManicurePedicure.ViewModels.HomePageViewModel

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="eyebrow">Cape Town luxury nail care</span>
                <h1 class="hero-title">Elegant manicure and pedicure appointments with a personal touch.</h1>
                <p class="hero-copy">For over 8 years, Nicky has helped women feel polished, confident, and beautifully cared for with refined nail services in Mowbray, Cape Town.</p>
                <div class="hero-actions">
                    <a class="btn btn-brand btn-lg" asp-controller="Booking" asp-action="Index">Request Appointment</a>
                    <a class="btn btn-outline-brand btn-lg" asp-controller="Services" asp-action="Index">View Services</a>
                </div>
                <ul class="trust-list">
                    <li>8+ years of experience</li>
                    <li>Premium, client-focused service</li>
                    <li>Cape Town based and easy to reach</li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="hero-card">
                    <div class="hero-stat">
                        <strong>Luxury service</strong>
                        <span>Tailored appointments with calm, professional care.</span>
                    </div>
                    <div class="hero-stat">
                        <strong>Beautiful finishes</strong>
                        <span>Soft glam, timeless tones, and occasion-ready polish.</span>
                    </div>
                    <div class="hero-stat">
                        <strong>Trust you can feel</strong>
                        <span>Clean standards, consistency, and thoughtful attention to detail.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-space">
    <div class="container">
        @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
        {
            Eyebrow = "Signature services",
            Title = "A polished menu designed around care, beauty, and confidence",
            Description = "Choose from a curated set of premium treatments created for everyday elegance and special moments."
        })

        <div class="row g-4">
            @foreach (var service in Model.FeaturedServices)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="service-card h-100">
                        <div class="service-meta">
                            <span>@service.Duration</span>
                            <span>@service.PriceFrom</span>
                        </div>
                        <h3>@service.Name</h3>
                        <p>@service.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section-space bg-blush">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Why women choose Nicky",
                    Title = "Luxury is not only how your nails look, but how you are treated",
                    Description = "From your first message to your final finish, the experience is built on warmth, professionalism, and careful detail.",
                    AlignmentClass = "text-start"
                })
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-md-4"><div class="trust-card"><strong>High-end feel</strong><p>Refined styling, premium care, and a calm appointment flow.</p></div></div>
                    <div class="col-md-4"><div class="trust-card"><strong>Client first</strong><p>Every service is shaped around your lifestyle, goals, and comfort.</p></div></div>
                    <div class="col-md-4"><div class="trust-card"><strong>Consistent quality</strong><p>Professional standards that help you book with confidence.</p></div></div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_TestimonialsSection", Model.Testimonials)

<section class="section-space">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Appointment request",
                    Title = "Reserve your next manicure or pedicure",
                    Description = "Share your preferred service and timing. We will confirm availability and guide you from there.",
                    AlignmentClass = "text-start"
                })
            </div>
            <div class="col-lg-7">
                <div class="form-panel">
                    @await Html.PartialAsync("_InquiryForm", Model.InquiryForm)
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_FaqSection", Model.FaqItems)
@await Html.PartialAsync("_ContactCallout")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
