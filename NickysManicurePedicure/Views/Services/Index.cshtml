@model NickysManicurePedicure.ViewModels.ServicesPageViewModel

<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Services</span>
        <h1>Curated manicure and pedicure treatments for polished, modern women.</h1>
        <p>Every service is delivered with attention to detail, lasting beauty, and a premium client experience.</p>
        <div class="hero-actions mt-4">
            <a class="btn btn-brand btn-lg" asp-controller="Booking" asp-action="Index">Book Your Appointment</a>
            <a class="btn btn-outline-brand btn-lg" href="#services-booking-form">Request From This Page</a>
        </div>
    </div>
</section>

<section class="section-space">
    <div class="container">
        <div class="row g-4">
            @foreach (var service in Model.Services)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="service-card h-100">
                        <div class="service-meta">
                            <span>@service.Duration</span>
                            <span>@service.PriceFrom</span>
                        </div>
                        <h2 class="h4">@service.Name</h2>
                        <p>@service.Description</p>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<section class="section-space pt-0">
    <div class="container">
        <div class="cta-panel booking-cta-panel">
            <div>
                <span class="eyebrow">Booking made easy</span>
                <h2>Seen the right service? Send your appointment request while it is fresh.</h2>
                <p>Choose your preferred treatment, date, and time, and we will confirm the best available slot.</p>
            </div>
            <div class="cta-actions">
                <a class="btn btn-brand btn-lg" asp-controller="Booking" asp-action="Index">Go to Booking Page</a>
                <a class="btn btn-outline-brand btn-lg" href="#services-booking-form">Request Here</a>
            </div>
        </div>
    </div>
</section>

<section class="section-space bg-ivory" id="services-booking-form">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-5">
                @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
                {
                    Eyebrow = "Booking",
                    Title = "Tell us what you would love",
                    Description = "Send your preferred service, date, and any special details so we can help you book beautifully.",
                    AlignmentClass = "text-start"
                })
            </div>
            <div class="col-lg-7">
                <div class="form-panel">
                    @await Html.PartialAsync("_BookingRequestForm", Model.BookingForm)
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
