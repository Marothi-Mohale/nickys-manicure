@using Microsoft.Extensions.Options
@using NickysManicurePedicure.Models.Options
@inject IOptions<BusinessProfileOptions> BusinessOptions
@{
    var business = BusinessOptions.Value;
}

<section class="section-space">
    <div class="container">
        <div class="cta-panel">
            <div>
                <span class="eyebrow">Ready to book?</span>
                <h2>Let your next appointment feel effortless, polished, and beautifully considered.</h2>
                <p>Call, WhatsApp, or send a request online and we will help you choose the right service for your schedule and style.</p>
            </div>
            <div class="cta-actions">
                <a class="btn btn-brand" href="@business.PhoneHref">Call Now</a>
                <a class="btn btn-outline-brand" href="@business.WhatsAppHref" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </div>
        </div>
    </div>
</section>
