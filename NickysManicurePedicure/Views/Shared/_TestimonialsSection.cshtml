@model IReadOnlyCollection<NickysManicurePedicure.Models.Entities.Testimonial>

<section class="section-space bg-ivory">
    <div class="container">
        @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
        {
            Eyebrow = "Client love",
            Title = "Trusted by women who value polish, calm, and consistency",
            Description = "A premium beauty appointment should feel graceful from beginning to end. These client reflections speak to that experience."
        })

        <div class="testimonials-strip">
            @foreach (var testimonial in Model)
            {
                <article class="testimonial-card">
                    <div class="testimonial-stars" aria-hidden="true">
                        @for (var star = 0; star < testimonial.Rating; star++)
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                    </div>
                    <p class="testimonial-copy">“@testimonial.Quote”</p>
                    <strong class="testimonial-name">@testimonial.ClientName</strong>
                </article>
            }
        </div>
    </div>
</section>
