@model IReadOnlyCollection<NickysManicurePedicure.Models.Entities.FaqItem>

<section class="section-space">
    <div class="container">
        @await Html.PartialAsync("_SectionHeader", new NickysManicurePedicure.ViewModels.SectionHeaderViewModel
        {
            Eyebrow = "FAQ",
            Title = "Helpful details before your visit",
            Description = "A few quick answers to make booking and planning effortless."
        })

        <div class="accordion premium-accordion" id="faqAccordion">
            @foreach (var item in Model)
            {
                var collapseId = $"faq-{item.Id}";
                <div class="accordion-item">
                    <h3 class="accordion-header" id="heading-@item.Id">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            @item.Question
                        </button>
                    </h3>
                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="heading-@item.Id" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">@item.Answer</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
