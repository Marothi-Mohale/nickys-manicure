@model NickysManicurePedicure.ViewModels.GalleryPageViewModel

<section class="page-hero">
    <div class="container">
        <span class="eyebrow">Gallery</span>
        <h1>A polished gallery of signature manicure and pedicure styling.</h1>
        <p>A curated visual edit of the salon aesthetic: soft luxury finishes, elegant detail, and presentation that feels premium without feeling crowded.</p>
    </div>
</section>

<section class="section-space">
    <div class="container">
        <div class="gallery-grid">
            @foreach (var item in Model.GalleryItems)
            {
                <article class="gallery-card">
                    <div class="gallery-art">
                        <img src="@item.ImageUrl" alt="@item.AltText" loading="lazy" decoding="async" />
                    </div>
                    <div class="gallery-body">
                        <span class="gallery-category">@(item.IsFeatured ? "Featured " : string.Empty)@item.Category</span>
                        <h2 class="h5">@item.Title</h2>
                        <p>@item.Description</p>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

@await Html.PartialAsync("_ContactCallout")
